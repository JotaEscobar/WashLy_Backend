# =========================================================
# Washly — Variables de Entorno
# Copiar a .env y configurar los valores
# =========================================================

# Django Core (OBLIGATORIO)
SECRET_KEY=generate-a-strong-random-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# CORS Configuration
CORS_ALLOW_ALL=False
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Database (Producción — PostgreSQL)
# DATABASE_URL=postgresql://user:password@localhost:5432/washly_db

# Email (para notificaciones)
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=your-email@gmail.com
# EMAIL_HOST_PASSWORD=your-app-password
# EMAIL_USE_TLS=True

# Sentry (para producción)
# SENTRY_DSN=https://your-sentry-dsn-here

# Celery
# CELERY_BROKER_URL=redis://localhost:6379/0
