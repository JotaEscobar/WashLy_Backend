# =========================================================
# Washly — Variables de Entorno
# Copiar a .env y configurar los valores
# =========================================================

# Django Core (OBLIGATORIO)
SECRET_KEY=generate-a-strong-random-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
FIELD_ENCRYPTION_KEY=your-32-byte-base64-key-here

# CORS Configuration
CORS_ALLOW_ALL=False
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Database (Producción — PostgreSQL)
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.vchqooonprcicbgoqvta.supabase.co:6543/postgres

# Supabase Storage (S3 Compatible)
USE_SUPABASE_STORAGE=False
SUPABASE_S3_KEY_ID=your-access-key-id
SUPABASE_S3_SECRET=your-secret-access-key
SUPABASE_BUCKET_NAME=washly-media
SUPABASE_PROJECT_ID=vchqooonprcicbgoqvta
SUPABASE_REGION=us-east-1

# Sentry (para monitoreo de errores en producción)
# SENTRY_DSN=https://your-sentry-dsn-here

# Celery
# CELERY_BROKER_URL=redis://localhost:6379/0
